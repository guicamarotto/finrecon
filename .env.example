# ================================================================
# FinRecon — Environment Variables
# Copy this file to .env and fill in the values before running.
# Usage: cp .env.example .env && docker compose up
# ================================================================

# PostgreSQL
POSTGRES_DB=finrecon
POSTGRES_USER=finrecon
POSTGRES_PASSWORD=finrecon_dev_password

# RabbitMQ
RABBITMQ_DEFAULT_USER=finrecon
RABBITMQ_DEFAULT_PASS=finrecon_dev_password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_password
MINIO_BUCKET_NAME=finrecon-uploads

# JWT
JWT_SECRET=dev-secret-key-change-in-production-must-be-at-least-32-chars

# API
API_PORT=5000

# Frontend
VITE_API_BASE_URL=http://localhost:5000
